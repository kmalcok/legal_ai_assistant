# ---- OpenAI ----
OPENAI_API_KEY_1=your_openai_key_1
OPENAI_API_KEY_2=your_openai_key_2

# ---- App Config Files ----
# App-level behavior lives in:
#   backend/config/config-dev/*.json
#   backend/config/config-prod/*.json
# Keep `.env` for secrets and infrastructure only.
# Supports either `config-dev` / `config-prod` or a direct folder path under `backend/`.
CONFIG_DIR=config-dev

# ---- Redis ----
# If running everything via docker compose, Redis is "redis" service:
# REDIS_URL=redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# ---- Elasticsearch ----
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_INDEX_ICTIHAT=ictihat
ELASTICSEARCH_VERIFY_CERTS=true

# ---- Qdrant ----
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_INDEX_ICTIHAT=ictihat

# ---- Database ----
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=
DB_NAME=mevzuat
DB_POOL_SIZE=10

# ---- JWT ----
JWT_SECRET=change-me-very-long-random
JWT_ALG=HS256
JWT_ISSUER=mevzuat-agent
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
JWT_LEEWAY_SECONDS=30
JWT_REFRESH_REUSE_GRACE_SECONDS=5

# ---- Credits ----
CREDIT_EXCHANGE_RATE=1
STUDENT_CREDIT_EXCHANGE_RATE=1

# ---- Mail ----
MAIL_VERIF_API_KEY=
MAILTRAP_API_KEY=
MAILTRAP_SENDER_EMAIL=noreply@mevzuat.local
MAILTRAP_SENDER_NAME=Mevzuat
