# Frontend environment variables (Vite)
#
# Copy this file to `.env.local` (recommended) or `.env` and adjust values.
#
# Frontend API calls read the backend base URL from `VITE_API_BASE_URL`.
# In local dev, the Vite `/v1` proxy also uses the same value.

# Backend base URL (no trailing slash), examples:
# VITE_API_BASE_URL=http://localhost:8000
# VITE_API_BASE_URL=https://api.your-domain.com
#VITE_API_BASE_URL=http://localhost:8000
VITE_API_BASE_URL=http://185.174.20.194

# Landing page demo video URL.
# Leave empty in local if you keep the file at `public/videos/yargucu-demo.mp4`.
# VITE_DEMO_VIDEO_URL=https://your-domain.com/assets/videos/yargucu-demo.mp4
#VITE_DEMO_VIDEO_URL=